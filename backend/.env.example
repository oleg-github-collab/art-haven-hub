# Required
DATABASE_URL=postgres://user:pass@localhost:5432/art_haven?sslmode=disable
JWT_SECRET=your-secret-key-min-32-chars-long

# Redis (optional, defaults to localhost)
REDIS_URL=redis://localhost:6379

# Server
PORT=8080
APP_ENV=development

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# File Upload
UPLOAD_DIR=./uploads
UPLOAD_BASE_URL=http://localhost:8080/files
UPLOAD_MAX_SIZE_MB=10

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUCCESS_URL=http://localhost:5173/payment/success
STRIPE_CANCEL_URL=http://localhost:5173/payment/error
STRIPE_PRO_PRICE_ID=price_...
STRIPE_GALLERY_PRICE_ID=price_...

# OpenAI (for translations + embeddings)
OPENAI_API_KEY=sk-...

# Migrations
MIGRATIONS_DIR=migrations
